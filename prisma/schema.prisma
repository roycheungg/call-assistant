generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Call {
  id          String   @id @default(cuid())
  vapiCallId  String   @unique
  phoneNumber String
  status      String   @default("completed") // completed, transferred, voicemail, failed
  duration    Int      @default(0) // seconds
  transcript  Json?    // full conversation transcript
  summary     String?  // AI-generated call summary
  sentiment   String?  // positive, neutral, negative
  recordingUrl String?
  costCents   Int?     // call cost in cents
  endReason   String?  // customer_ended, assistant_ended, error
  leadId      String?
  lead        Lead?    @relation(fields: [leadId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([phoneNumber])
  @@index([createdAt])
  @@map("ca_calls")
}

model Lead {
  id        String     @id @default(cuid())
  name      String?
  email     String?
  phone     String
  company   String?
  issue     String?    // what they called about
  status    String     @default("new") // new, callback_booked, contacted, resolved, lost
  source    String     @default("phone") // phone, manual, whatsapp, website
  notes     String?
  calls     Call[]
  callbacks Callback[]
  whatsappConversations WhatsAppConversation[]
  websiteConversations  WebsiteConversation[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([phone])
  @@index([status])
  @@index([createdAt])
  @@map("ca_leads")
}

model Callback {
  id          String   @id @default(cuid())
  leadId      String
  lead        Lead     @relation(fields: [leadId], references: [id])
  assignedTo  String   // team member name or email
  scheduledAt DateTime
  status      String   @default("pending") // pending, completed, missed, cancelled
  notes       String?
  calendarEventId String? // Google Calendar event ID
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([scheduledAt])
  @@index([status])
  @@map("ca_callbacks")
}

model BusinessSettings {
  id                    String @id @default("default")
  businessName          String @default("DOAI Systems")
  businessDescription   String @default("")
  services              Json   @default("[]")
  teamMembers           Json   @default("[]")
  operatingHours        Json   @default("{}")
  greetingMessage       String?
  vapiAssistantId       String?
  vapiPhoneNumberId     String?
  whatsappSystemPrompt  String?
  whatsappEnabled       Boolean @default(false)
  updatedAt             DateTime @updatedAt

  @@map("ca_business_settings")
}

model WhatsAppConversation {
  id            String   @id @default(cuid())
  waId          String   @unique
  phoneNumber   String
  contactName   String?
  leadId        String?
  lead          Lead?    @relation(fields: [leadId], references: [id])
  status        String   @default("active") // active, closed, archived
  isRead        Boolean  @default(false)
  starred       Boolean  @default(false)
  lastMessageAt DateTime @default(now())
  messages      WhatsAppMessage[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("ca_whatsapp_conversations")
  @@index([waId])
  @@index([phoneNumber])
  @@index([status])
  @@index([lastMessageAt])
}

model WhatsAppMessage {
  id             String   @id @default(cuid())
  conversationId String
  conversation   WhatsAppConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String   // "user" or "assistant"
  content        String
  waMessageId    String?  @unique
  status         String   @default("sent") // sent, delivered, read, failed
  createdAt      DateTime @default(now())

  @@map("ca_whatsapp_messages")
  @@index([conversationId])
  @@index([createdAt])
}

model WebsiteConfig {
  id              String   @id @default(cuid())
  siteId          String   @unique
  name            String
  botName         String   @default("Assistant")
  systemPrompt    String
  greeting        String?
  quickReplies    Json     @default("[]")
  brandColor      String   @default("#2563eb")
  allowedOrigins  Json     @default("[]")
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  conversations   WebsiteConversation[]

  @@map("ca_website_configs")
}

model WebsiteConversation {
  id            String   @id @default(cuid())
  siteId        String
  site          WebsiteConfig @relation(fields: [siteId], references: [siteId])
  sessionId     String   @unique
  leadId        String?
  lead          Lead?    @relation(fields: [leadId], references: [id])
  visitorName   String?
  visitorEmail  String?
  visitorPhone  String?
  status        String   @default("active")
  isRead        Boolean  @default(false)
  starred       Boolean  @default(false)
  lastMessageAt DateTime @default(now())
  userAgent     String?
  referrer      String?
  messages      WebsiteMessage[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("ca_website_conversations")
  @@index([siteId])
  @@index([sessionId])
  @@index([lastMessageAt])
}

model WebsiteMessage {
  id             String   @id @default(cuid())
  conversationId String
  conversation   WebsiteConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String   // "user" or "assistant"
  content        String
  createdAt      DateTime @default(now())

  @@map("ca_website_messages")
  @@index([conversationId])
}
